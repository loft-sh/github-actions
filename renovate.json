{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "packageRules": [
    {
      "description": "Group all GitHub Actions updates into a single PR",
      "matchManagers": ["github-actions"],
      "groupName": "github-actions"
    },
    {
      "description": "Group semver-validation npm dependencies",
      "matchManagers": ["npm"],
      "groupName": "semver-validation"
    },
    {
      "description": "Group linear-pr-commenter Go dependencies",
      "matchManagers": ["gomod"],
      "groupName": "linear-pr-commenter"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update zizmor version pinned inline in CI workflow",
      "managerFilePatterns": ["/^\\.github/workflows/ci\\.yaml$/"],
      "matchStrings": ["pip install zizmor==(?<currentValue>[^\\s&]+)"],
      "depNameTemplate": "zizmor",
      "datasourceTemplate": "pypi"
    },
    {
      "customType": "regex",
      "description": "Update renovate version pinned in validate-renovate workflow",
      "managerFilePatterns": ["/^\\.github/workflows/validate-renovate\\.yaml$/"],
      "matchStrings": ["renovate@(?<currentValue>[^\\s]+)"],
      "depNameTemplate": "renovate",
      "datasourceTemplate": "npm"
    }
  ]
}
